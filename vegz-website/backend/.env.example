# ═══════════════════════════════════════════════════════
#  VEGZ BACKEND — Environment Variables
#  Frontend + Backend: EC2 Server 1 (vegz.online)
#  MySQL Database:     EC2 Server 2 (private IP)
#
#  Copy this to .env — NEVER commit .env to git
# ═══════════════════════════════════════════════════════

NODE_ENV=production
PORT=5001

# ── DATABASE — EC2 Server 2 ─────────────────────────────
# Server 2 private IP (within same AWS VPC — no public internet)
# Example: 10.0.1.25 (your Server 2 private IP from AWS console)
DB_HOST=10.0.1.XXX
DB_PORT=3306
DB_USER=vegz_user
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE
DB_NAME=vegz_db
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── JWT ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PASTE_YOUR_64_CHAR_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=30d

# ── OTP ──────────────────────────────────────────────────
# Set OTP_DEV_MODE=false in production
OTP_DEV_MODE=false
OTP_DEV_FIXED=123456
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── SMS — MSG91 (Indian, cheapest ~₹0.20/SMS) ───────────
# Sign up at msg91.com, create OTP template
# Template text: "Your Vegz OTP is ##OTP##. Valid for 10 minutes. Do not share."
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
MSG91_TEMPLATE_ID=YOUR_MSG91_TEMPLATE_ID
MSG91_SENDER_ID=VEGZAP

# ── OR Twilio (international) ────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── CORS ─────────────────────────────────────────────────
# Allow both www and non-www + mobile app origins
CORS_ORIGINS=https://vegz.online,https://www.vegz.online,https://api.vegz.online

# ── Rate limits ───────────────────────────────────────────
OTP_RATE_LIMIT_MAX=5
RATE_LIMIT_MAX=300

# ── Dev only (override above for local testing) ───────────
# DB_HOST=localhost
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
# OTP_DEV_MODE=true
